{
  "name": "yoga-studio-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:coverage": "INSTRUMENT_COVERAGE=true vite",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "start-server-and-test dev:coverage http://localhost:3000 cypress:run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "axios": "^1.13.4",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.1.7",
    "cypress": "^15.16.0",
    "jsdom": "^29.1.1",
    "nyc": "^18.0.0",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.7"
  }
}
